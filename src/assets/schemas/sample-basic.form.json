{
  "id": "sample-basic",
  "title": "Basic Registration",
  "version": "1.0.0",
  "description": "Simple multi-section form with static validation.",
  "hiddenValuePolicy": "clear",
  "sections": [
    {
      "id": "personal",
      "title": "Personal Details",
      "order": 1,
      "fields": [
        {
          "id": "fullName",
          "label": "Full Name",
          "type": "text",
          "order": 1,
          "required": true,
          "placeholder": "Enter your full name",
          "validation": [
            { "type": "required", "message": "Full name is required" },
            { "type": "minLength", "value": 2, "message": "At least 2 characters" }
          ]
        },
        {
          "id": "email",
          "label": "Email",
          "type": "text",
          "order": 2,
          "keyboardType": "email-address",
          "required": true,
          "validation": [
            { "type": "required", "message": "Email is required" },
            {
              "type": "pattern",
              "value": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$",
              "message": "Enter a valid email"
            }
          ]
        }
      ]
    },
    {
      "id": "preferences",
      "title": "Preferences",
      "order": 2,
      "fields": [
        {
          "id": "contactMethod",
          "label": "Preferred Contact",
          "type": "radio",
          "order": 1,
          "required": true,
          "options": [
            { "label": "Email", "value": "email" },
            { "label": "Phone", "value": "phone" }
          ]
        },
        {
          "id": "interests",
          "label": "Interests",
          "type": "checkbox",
          "order": 2,
          "options": [
            { "label": "Sports", "value": "sports" },
            { "label": "Music", "value": "music" },
            { "label": "Tech", "value": "tech" }
          ],
          "validation": [
            { "type": "minSelections", "value": 1, "message": "Select at least one" },
            { "type": "maxSelections", "value": 3, "message": "Select up to three" }
          ]
        }
      ]
    }
  ]
}
